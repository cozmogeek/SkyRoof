  <!-- The VE3NEA.SkySignals solution owns/builds VE3NEA.SkyTlm.dll; SkyRoof never builds it, it only references
       the vendored copy under Vendor\VE3NEA.SkyTlm. On the maintainer's machine (where the sibling repo is
       present) the copy is refreshed from that solution's latest build; Inputs/Outputs make it run only when the
       built dll is newer (date-gated). Forks/CI have no sibling build → the committed Vendor copy is used as-is. -->
  <PropertyGroup>
    <TlmRepoDll>$(MSBuildThisFileDirectory)..\..\VE3NEA.SkySignals\VE3NEA.SkyTlm\bin\x64\$(Configuration)\net10.0-windows\VE3NEA.SkyTlm.dll</TlmRepoDll>
    <TlmVendorDir>$(MSBuildThisFileDirectory)..\Vendor\VE3NEA.SkyTlm\</TlmVendorDir>
  </PropertyGroup>

  <Target Name="RefreshVendoredTlm" BeforeTargets="ResolveAssemblyReferences"
          Condition="Exists('$(TlmRepoDll)')"
          Inputs="$(TlmRepoDll)" Outputs="$(TlmVendorDir)VE3NEA.SkyTlm.dll">
    <Copy SourceFiles="$(TlmRepoDll)" DestinationFolder="$(TlmVendorDir)" SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <Reference Include="VE3NEA.SkyTlm">
      <HintPath>$(TlmVendorDir)VE3NEA.SkyTlm.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <Target Name="ExcludeRootSystemSpeechFromBuildOutput" AfterTargets="ResolveReferences">
    <ItemGroup>
      <ReferenceCopyLocalPaths Remove="@(ReferenceCopyLocalPaths)" Condition="'%(ReferenceCopyLocalPaths.Filename)%(ReferenceCopyLocalPaths.Extension)' == 'System.Speech.dll' and '%(ReferenceCopyLocalPaths.DestinationSubDirectory)' == ''" />
    </ItemGroup>
  </Target>

  <Target Name="ExcludeRootSystemSpeechFromPublishOutput" AfterTargets="ComputeResolvedFilesToPublishList">
    <ItemGroup>
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)" Condition="'%(ResolvedFileToPublish.Filename)%(ResolvedFileToPublish.Extension)' == 'System.Speech.dll' and '%(ResolvedFileToPublish.RelativePath)' == 'System.Speech.dll'" />
    </ItemGroup>
  </Target>

</Project>
