  <!-- VE3NEA.Dsp is built by the VE3NEA.SkySignals sibling solution, not by SkyRoof. Its vendored copy under
       Vendor\VE3NEA.Dsp is refreshed from that solution's latest build when present (date-gated); forks/CI
       with no sibling build use the committed copy as-is. -->
  <PropertyGroup>
    <DspRepoDll>$(MSBuildThisFileDirectory)..\..\VE3NEA.SkySignals\VE3NEA.Dsp\bin\x64\$(Configuration)\net10.0\VE3NEA.Dsp.dll</DspRepoDll>
    <DspVendorDir>$(MSBuildThisFileDirectory)..\Vendor\VE3NEA.Dsp\</DspVendorDir>
  </PropertyGroup>

  <Target Name="RefreshVendoredDsp" BeforeTargets="ResolveAssemblyReferences"
          Condition="Exists('$(DspRepoDll)')"
          Inputs="$(DspRepoDll)" Outputs="$(DspVendorDir)VE3NEA.Dsp.dll">
    <Copy SourceFiles="$(DspRepoDll)" DestinationFolder="$(DspVendorDir)" SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <Reference Include="VE3NEA.Dsp">
      <HintPath>$(DspVendorDir)VE3NEA.Dsp.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

